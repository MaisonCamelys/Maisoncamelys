.page {
  background: #F6F1E9;
  color: #1F1D1A;
}

.container {
  width: min(1220px, calc(100% - 48px));
  margin: 0 auto;
}

.hero {
  width: 100%;
  overflow: hidden;
  background: #0F1A14;
}

.heroImage {
  width: 100%;
  display: block;
  height: auto;
}

.label,
.labelCenter {
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #C6A16E;
}

.labelCenter {
  text-align: center;
  display: block;
  margin-bottom: 14px;
}

.sectionTitle {
  font-family: var(--serif);
  font-size: clamp(30px, 3vw, 44px);
  font-weight: 400;
  line-height: 1.25;
  text-align: center;
  color: #1F1D1A;
  margin-bottom: 42px;
}


.conviction {
  padding: 96px 0 104px;
  background:
    linear-gradient(180deg, #F6F1E9 0%, #F1E8DD 100%);
  position: relative;
  overflow: hidden;
}

.convictionShell {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  gap: 72px;
  align-items: center;
}

.convictionText {
  max-width: 560px;
}

.convictionTitle {
  font-family: var(--serif);
  font-size: clamp(46px, 5vw, 74px);
  line-height: 1.08;
  font-weight: 400;
  margin-top: 16px;
  letter-spacing: -0.02em;
  color: #201D19;
}

.convictionTitle em {
  font-style: italic;
  color: #75836A;
}

.convictionBody {
  margin-top: 28px;
  font-size: 17px;
  line-height: 1.95;
  color: #5E5852;
  max-width: 520px;
}

.convictionBodySecondary {
  margin-top: 14px;
  font-size: 15px;
  line-height: 1.95;
  color: #7A7269;
  max-width: 500px;
}

.convictionLink {
  margin-top: 28px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #C6A16E;
  position: relative;
}

.convictionLink::after {
  content: '→';
  font-size: 13px;
  line-height: 1;
}

.convictionVisual {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 190px;
  gap: 18px;
  align-items: end;
}

.convictionMainCard,
.convictionSmallCard {
  background: rgba(252, 248, 242, 0.82);
  border: 1px solid rgba(198, 161, 110, 0.12);
  border-radius: 18px;
  padding: 10px;
  box-shadow:
    0 30px 60px rgba(31, 29, 26, 0.08),
    0 10px 20px rgba(31, 29, 26, 0.04);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.convictionMainCard {
  transform: translateY(-10px);
}

.convictionMainCard img,
.convictionSmallCard img {
  width: 100%;
  display: block;
  object-fit: cover;
  border-radius: 12px;
}

.convictionMainCard img {
  aspect-ratio: 1.1 / 0.95;
}

.convictionSideGrid {
  display: grid;
  gap: 16px;
}

.convictionSmallCard img {
  aspect-ratio: 1 / 1;
}



.duo {
  padding: 104px 0 110px;
  background:
    radial-gradient(circle at top left, rgba(232, 207, 164, 0.08), transparent 28%),
    radial-gradient(circle at bottom right, rgba(232, 207, 164, 0.06), transparent 24%),
    linear-gradient(180deg, #182117 0%, #11170F 100%);
  position: relative;
  overflow: hidden;
}

.duoIntro {
  text-align: center;
  max-width: 820px;
  margin: 0 auto 56px;
}

.duoLabel {
  font-size: 10px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: #C6A16E;
}

.duoTitle {
  margin-top: 16px;
  font-family: var(--serif);
  font-size: clamp(38px, 4vw, 58px);
  line-height: 1.12;
  font-weight: 400;
  color: #F7F2EA;
}

.duoLead {
  margin: 18px auto 0;
  max-width: 650px;
  font-size: 15px;
  line-height: 1.9;
  color: rgba(247, 242, 234, 0.72);
}

.duoEditorial {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 260px minmax(0, 1fr);
  gap: 26px;
  align-items: stretch;
}

.duoPanel {
  background: rgba(247, 242, 234, 0.05);
  border: 1px solid rgba(232, 207, 164, 0.12);
  border-radius: 24px;
  overflow: hidden;
  box-shadow:
    0 24px 60px rgba(0, 0, 0, 0.18),
    inset 0 1px 0 rgba(255,255,255,0.04);
}

.duoPanelImage {
  padding: 12px 12px 0;
}

.duoPanelImage img {
  width: 100%;
  height: 360px;
  object-fit: cover;
  display: block;
  border-radius: 16px;
}

.duoPanelContent {
  padding: 24px 24px 28px;
}

.duoPanelKicker {
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #C6A16E;
}

.duoPanelContent h3 {
  margin-top: 12px;
  font-family: var(--serif);
  font-size: 34px;
  line-height: 1.1;
  font-weight: 400;
  color: #F7F2EA;
}

.duoPanelContent p:last-child {
  margin-top: 16px;
  font-size: 14px;
  line-height: 1.9;
  color: rgba(247, 242, 234, 0.74);
  max-width: 420px;
}

.duoCenter {
  display: flex;
  align-items: center;
  justify-content: center;
}

.duoCenterCard {
  width: 100%;
  min-height: 100%;
  border-radius: 24px;
  padding: 28px 24px;
  background: linear-gradient(180deg, rgba(198, 161, 110, 0.12), rgba(198, 161, 110, 0.06));
  border: 1px solid rgba(232, 207, 164, 0.16);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow:
    0 24px 60px rgba(0, 0, 0, 0.16),
    inset 0 1px 0 rgba(255,255,255,0.04);
}

.duoCenterLogo {
  width: 110px;
  height: auto;
  display: block;
  opacity: 0.95;
}

.duoCenterText {
  margin-top: 22px;
  text-align: center;
  font-size: 13px;
  line-height: 1.9;
  color: rgba(247, 242, 234, 0.78);
}

.duoPanelLeft {
  transform: translateY(18px);
}

.duoPanelRight {
  transform: translateY(-18px);
}


.band {
  position: relative;
  background:
    linear-gradient(rgba(23, 27, 18, 0.72), rgba(23, 27, 18, 0.72)),
    url("/images/ambiance/first-dance.png") center/cover no-repeat;
  color: #fff;
  padding: 68px 0 76px;
}

.bandInner {
  position: relative;
  width: min(1220px, calc(100% - 48px));
  margin: 0 auto;
  text-align: center;
}

.bandTitle {
  font-family: var(--serif);
  font-size: clamp(30px, 3vw, 42px);
  font-weight: 400;
  line-height: 1.24;
  color: #FDF9F3;
}

.bandFacts {
  margin-top: 34px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.bandFacts div {
  padding-top: 18px;
  border-top: 1px solid rgba(232, 207, 164, 0.18);
}

.bandFacts strong {
  display: block;
  font-family: var(--serif);
  font-size: 20px;
  color: #E8CFA4;
  font-weight: 500;
}

.bandFacts span {
  display: block;
  margin-top: 8px;
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(253, 249, 243, 0.7);
}

.prestations {
  padding: 86px 0 92px;
  background: #F6F1E9;
}

.prestationsGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

.prestationCard {
  background: #FCF8F2;
  border: 1px solid rgba(198, 161, 110, 0.14);
  border-radius: 12px;
  padding: 14px 14px 18px;
}

.prestationCard img {
  width: 100%;
  aspect-ratio: 1.08 / 0.86;
  object-fit: cover;
  border-radius: 8px;
}

.prestationCard h3 {
  margin-top: 14px;
  font-family: var(--serif);
  font-size: 22px;
  line-height: 1.2;
  font-weight: 500;
  color: #1F1D1A;
}

.prestationCard p {
  margin-top: 10px;
  font-size: 13px;
  line-height: 1.8;
  color: #5F5A53;
}

.pricing {
  padding: 0 0 96px;
  background: #F6F1E9;
}

.pricingGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}

.priceCard {
  background: #FCF8F2;
  border: 1px solid rgba(198, 161, 110, 0.14);
  border-radius: 14px;
  padding: 28px 24px;
}

.featured {
  background: #F3EADF;
  border-color: rgba(198, 161, 110, 0.3);
  transform: translateY(-4px);
}

.priceCard h3 {
  font-family: var(--serif);
  font-size: 28px;
  font-weight: 500;
  color: #1F1D1A;
}

.priceText {
  margin-top: 10px;
  font-size: 13px;
  line-height: 1.8;
  color: #5F5A53;
}

.priceCard ul {
  margin-top: 18px;
  display: grid;
  gap: 8px;
}

.priceCard li {
  font-size: 13px;
  line-height: 1.7;
  color: #5F5A53;
}

.priceWrap {
  margin-top: 22px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.price {
  font-family: var(--serif);
  font-size: 42px;
  line-height: 1;
  color: #1F1D1A;
}

.priceWrap small {
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #C6A16E;
}

.finalCta {
  background: #12160F;
  padding: 96px 0 104px;
  text-align: center;
}

.finalTitle {
  font-family: var(--serif);
  font-size: clamp(36px, 4vw, 56px);
  line-height: 1.1;
  font-weight: 400;
  color: #FDF9F3;
}

.finalText {
  margin: 20px auto 0;
  max-width: 720px;
  font-size: 15px;
  line-height: 1.9;
  color: rgba(253, 249, 243, 0.72);
}

.ctaButton {
  margin-top: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  padding: 0 26px;
  border-radius: 999px;
  background: #C6A16E;
  color: white;
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

@media (max-width: 980px) {
  .duoEditorial {
    grid-template-columns: 1fr;
    gap: 22px;
  }

  .duoPanelLeft,
  .duoPanelRight {
    transform: none;
  }

  .duoCenter {
    order: 2;
  }

  .duoEditorial {
    grid-template-columns: 1fr;
    gap: 22px;
  }

  .duoPanelLeft,
  .duoPanelRight {
    transform: none;
  }

  .duoCenter {
    order: 2;
  }

  .convictionShell {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .convictionVisual {
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
  }

  .convictionSideGrid {
    gap: 18px;
  }

  .conviction .container,
  .bandFacts,
  .prestationsGrid,
  .pricingGrid {
    grid-template-columns: 1fr 1fr;
  }

  .duoGrid {
    grid-template-columns: 1fr;
  }

  .convictionImages {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 720px) {
  .duo {
    padding: 78px 0 82px;
  }

  .duoTitle {
    font-size: 42px;
  }

  .duoPanelImage img {
    height: 260px;
  }

  .duoPanelContent h3 {
    font-size: 28px;
  }

  .duo {
    padding: 78px 0 82px;
  }

  .duoTitle {
    font-size: 42px;
  }

  .duoPanelImage img {
    height: 260px;
  }

  .duoPanelContent h3 {
    font-size: 28px;
  }

  .conviction {
    padding: 72px 0 78px;
  }

  .convictionTitle {
    font-size: 48px;
    line-height: 1.12;
  }

  .convictionBody,
  .convictionBodySecondary {
    font-size: 15px;
    line-height: 1.85;
  }

  .convictionVisual {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .convictionSideGrid {
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .convictionMainCard {
    transform: none;
  }

  .container,
  .bandInner {
    width: min(100% - 32px, 1220px);
  }

  .conviction .container,
  .bandFacts,
  .prestationsGrid,
  .pricingGrid {
    grid-template-columns: 1fr;
  }

  .featured {
    transform: none;
  }
}



:global(.reveal) {
  opacity: 0;
  will-change: transform, opacity;
  transition:
    opacity 1.15s cubic-bezier(0.16, 1, 0.3, 1),
    transform 1.15s cubic-bezier(0.16, 1, 0.3, 1);
}

:global(.reveal-up) {
  transform: translate3d(0, 18px, 0);
}

:global(.reveal-fade) {
  transform: translate3d(0, 8px, 0);
}

:global(.reveal-delay-1) {
  transition-delay: 0.08s;
}

:global(.reveal-delay-2) {
  transition-delay: 0.14s;
}

:global(.reveal-delay-3) {
  transition-delay: 0.2s;
}

:global(.reveal.is-visible) {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

@media (prefers-reduced-motion: reduce) {
  :global(.reveal),
  :global(.reveal-up),
  :global(.reveal-fade),
  :global(.reveal-delay-1),
  :global(.reveal-delay-2),
  :global(.reveal-delay-3) {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
    filter: none !important;
  }
}

















@media (max-width: 980px) {
  .editorialPrestationsGrid {
    grid-template-columns: 1fr;
  }

  .editorialCardLarge .editorialCardImage {
    height: 320px;
  }
}

@media (max-width: 720px) {
  .editorialPrestations {
    padding: 82px 0 88px;
  }

  .editorialPrestationsTitle {
    font-size: 40px;
  }

  .editorialCardLarge .editorialCardImage {
    height: 260px;
  }

  .editorialCardSmall .editorialCardImage {
    height: 210px;
  }

  .editorialCardBody h3 {
    font-size: 28px;
  }

  .editorialCardSmallBody h4 {
    font-size: 22px;
  }
}

@media (hover: none) {
  .editorialCardLarge:hover,
  .editorialCardSmall:hover {
    transform: none;
  }

  .editorialCardLarge:hover .editorialCardImage,
  .editorialCardSmall:hover .editorialCardImage {
    transform: none;
  }
}



.prestationsTimeline {
  padding: 128px 0 120px;
  background:
    radial-gradient(circle at top left, rgba(198, 161, 110, 0.10), transparent 26%),
    linear-gradient(180deg, #F5EFE6 0%, #F2ECE3 100%);
  position: relative;
  overflow: hidden;
}

.timelineIntro {
  max-width: 820px;
  margin: 0 auto;
  text-align: center;
}

.timelineLabel {
  font-size: 10px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: #C6A16E;
}

.timelineTitle {
  margin-top: 18px;
  font-family: var(--serif);
  font-size: clamp(40px, 4.9vw, 72px);
  line-height: 1.04;
  font-weight: 400;
  letter-spacing: -0.025em;
  color: #1F1D1A;
}

.timelineLead {
  margin: 22px auto 0;
  max-width: 660px;
  font-size: 16px;
  line-height: 1.95;
  color: #5F5952;
}

.timelineHero {
  position: relative;
  margin-top: 56px;
}

.timelineHeroImage {
  width: 100%;
  height: 720px;
  object-fit: cover;
  display: block;
  border-radius: 34px;
  box-shadow:
    0 34px 80px rgba(31, 29, 26, 0.10),
    0 12px 30px rgba(31, 29, 26, 0.05);
}

.timelineHeroCard {
  position: absolute;
  left: 38px;
  bottom: 38px;
  width: min(430px, calc(100% - 76px));
  padding: 24px 24px 26px;
  border-radius: 24px;
  background: rgba(252, 248, 242, 0.88);
  border: 1px solid rgba(198, 161, 110, 0.20);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow:
    0 20px 50px rgba(31, 29, 26, 0.10),
    inset 0 1px 0 rgba(255,255,255,0.30);
}

.timelineHeroKicker {
  display: inline-block;
  font-size: 10px;
  letter-spacing: 0.20em;
  text-transform: uppercase;
  color: #8E6B3B;
}

.timelineHeroCard p {
  margin-top: 12px;
  font-size: 14px;
  line-height: 1.9;
  color: #4F4A44;
}

.timelineSequence {
  margin-top: 72px;
  display: grid;
  gap: 34px;
}

.timelineScene {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  gap: 34px;
  align-items: center;
}

.timelineSceneOffset {
  grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
}

.timelineScenePrimary .timelineSceneMedia img {
  height: 620px;
}

.timelineSceneMedia {
  position: relative;
}

.timelineSceneMedia img {
  width: 100%;
  height: 500px;
  object-fit: cover;
  display: block;
  border-radius: 30px;
  box-shadow:
    0 26px 60px rgba(31, 29, 26, 0.08),
    0 10px 24px rgba(31, 29, 26, 0.04);
  transition:
    transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
    box-shadow 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.timelineScene:hover .timelineSceneMedia img {
  transform: scale(1.018);
  box-shadow:
    0 32px 70px rgba(31, 29, 26, 0.10),
    0 12px 28px rgba(31, 29, 26, 0.05);
}

.timelineSceneContent {
  max-width: 500px;
}

.timelineNumber {
  font-family: var(--serif);
  font-size: 52px;
  line-height: 1;
  font-weight: 400;
  color: rgba(198, 161, 110, 0.95);
}

.timelineEyebrow {
  margin-top: 18px;
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #8E846F;
}

.timelineSceneContent h3 {
  margin-top: 14px;
  font-family: var(--serif);
  font-size: clamp(30px, 3vw, 46px);
  line-height: 1.08;
  font-weight: 400;
  letter-spacing: -0.02em;
  color: #1F1D1A;
}

.timelineSceneContent p:last-child {
  margin-top: 18px;
  font-size: 15px;
  line-height: 1.95;
  color: #605B54;
}

.timelineClosing {
  margin-top: 62px;
  padding-top: 34px;
  border-top: 1px solid rgba(198, 161, 110, 0.18);
  text-align: center;
}

.timelineClosingText {
  max-width: 860px;
  margin: 0 auto;
  font-family: var(--serif);
  font-size: clamp(24px, 2.4vw, 38px);
  line-height: 1.28;
  font-weight: 400;
  color: #26231F;
}

.timelineLink {
  margin-top: 24px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  letter-spacing: 0.20em;
  text-transform: uppercase;
  color: #8E6B3B;
}

.timelineLink::after {
  content: '→';
  font-size: 13px;
  line-height: 1;
}

@media (max-width: 1100px) {
  .timelineHeroImage {
    height: 620px;
  }

  .timelineScene,
  .timelineSceneOffset {
    grid-template-columns: 1fr;
    gap: 22px;
  }

  .timelineSceneOffset .timelineSceneContent {
    order: 1;
  }

  .timelineSceneOffset .timelineSceneMedia {
    order: 2;
  }

  .timelineScenePrimary .timelineSceneMedia img,
  .timelineSceneMedia img {
    height: 460px;
  }

  .timelineSceneContent {
    max-width: 100%;
  }
}

@media (max-width: 760px) {
  .prestationsTimeline {
    padding: 92px 0 88px;
  }

  .timelineTitle {
    font-size: 42px;
  }

  .timelineLead {
    font-size: 15px;
  }

  .timelineHero {
    margin-top: 38px;
  }

  .timelineHeroImage {
    height: 420px;
    border-radius: 24px;
  }

  .timelineHeroCard {
    position: static;
    width: 100%;
    margin-top: 16px;
    padding: 20px 18px 22px;
    border-radius: 20px;
  }

  .timelineSequence {
    margin-top: 46px;
    gap: 26px;
  }

  .timelineScenePrimary .timelineSceneMedia img,
  .timelineSceneMedia img {
    height: 300px;
    border-radius: 22px;
  }

  .timelineNumber {
    font-size: 40px;
  }

  .timelineSceneContent h3 {
    font-size: 28px;
  }

  .timelineClosing {
    margin-top: 42px;
    padding-top: 28px;
  }

  .timelineClosingText {
    font-size: 28px;
  }
}

@media (hover: none) {
  .timelineScene:hover .timelineSceneMedia img {
    transform: none;
    box-shadow:
      0 26px 60px rgba(31, 29, 26, 0.08),
      0 10px 24px rgba(31, 29, 26, 0.04);
  }
}

