.page {
  background: #F6F1E9;
  color: #1F1D1A;
}

.container {
  width: min(1220px, calc(100% - 48px));
  margin: 0 auto;
}

.hero {
  width: 100%;
  overflow: hidden;
  background: #0F1A14;
}

.heroImage {
  width: 100%;
  display: block;
  height: auto;
}

.label,
.labelCenter {
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #C6A16E;
}

.labelCenter {
  text-align: center;
  display: block;
  margin-bottom: 14px;
}

.sectionTitle {
  font-family: var(--serif);
  font-size: clamp(30px, 3vw, 44px);
  font-weight: 400;
  line-height: 1.25;
  text-align: center;
  color: #1F1D1A;
  margin-bottom: 42px;
}


.conviction {
  padding: 96px 0 104px;
  background:
    linear-gradient(180deg, #F6F1E9 0%, #F1E8DD 100%);
  position: relative;
  overflow: hidden;
}

.convictionShell {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  gap: 72px;
  align-items: center;
}

.convictionText {
  max-width: 560px;
}

.convictionTitle {
  font-family: var(--serif);
  font-size: clamp(46px, 5vw, 74px);
  line-height: 1.08;
  font-weight: 400;
  margin-top: 16px;
  letter-spacing: -0.02em;
  color: #201D19;
}

.convictionTitle em {
  font-style: italic;
  color: #75836A;
}

.convictionBody {
  margin-top: 28px;
  font-size: 17px;
  line-height: 1.95;
  color: #5E5852;
  max-width: 520px;
}

.convictionBodySecondary {
  margin-top: 14px;
  font-size: 15px;
  line-height: 1.95;
  color: #7A7269;
  max-width: 500px;
}

.convictionLink {
  margin-top: 28px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #C6A16E;
  position: relative;
}

.convictionLink::after {
  content: '→';
  font-size: 13px;
  line-height: 1;
}

.convictionVisual {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 190px;
  gap: 18px;
  align-items: end;
}

.convictionMainCard,
.convictionSmallCard {
  background: rgba(252, 248, 242, 0.82);
  border: 1px solid rgba(198, 161, 110, 0.12);
  border-radius: 18px;
  padding: 10px;
  box-shadow:
    0 30px 60px rgba(31, 29, 26, 0.08),
    0 10px 20px rgba(31, 29, 26, 0.04);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.convictionMainCard {
  transform: translateY(-10px);
}

.convictionMainCard img,
.convictionSmallCard img {
  width: 100%;
  display: block;
  object-fit: cover;
  border-radius: 12px;
}

.convictionMainCard img {
  aspect-ratio: 1.1 / 0.95;
}

.convictionSideGrid {
  display: grid;
  gap: 16px;
}

.convictionSmallCard img {
  aspect-ratio: 1 / 1;
}


.duo {
  padding: 12px 0 86px;
  background: #F6F1E9;
}

.duoHead {
  text-align: center;
  margin-bottom: 38px;
}

.duoGrid {
  display: grid;
  grid-template-columns: 1fr 180px 1fr;
  gap: 26px;
  align-items: center;
}

.personCard {
  text-align: center;
}

.personPhoto {
  width: 132px;
  height: 132px;
  margin: 0 auto 18px;
  border-radius: 999px;
  overflow: hidden;
  box-shadow: 0 12px 26px rgba(31,29,26,0.08);
}

.personPhoto img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.personCard h3 {
  font-size: 12px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #1F1D1A;
}

.personRole {
  margin-top: 8px;
  font-size: 12px;
  color: #718066;
}

.personCard p:last-child {
  margin: 12px auto 0;
  max-width: 290px;
  font-size: 13px;
  line-height: 1.8;
  color: #5F5A53;
}

.duoCenterMark {
  display: flex;
  align-items: center;
  justify-content: center;
}

.duoCenterMark img {
  width: 90px;
  height: auto;
  opacity: 0.95;
}

.band {
  position: relative;
  background:
    linear-gradient(rgba(23, 27, 18, 0.72), rgba(23, 27, 18, 0.72)),
    url("/images/ambiance/first-dance.png") center/cover no-repeat;
  color: #fff;
  padding: 68px 0 76px;
}

.bandInner {
  position: relative;
  width: min(1220px, calc(100% - 48px));
  margin: 0 auto;
  text-align: center;
}

.bandTitle {
  font-family: var(--serif);
  font-size: clamp(30px, 3vw, 42px);
  font-weight: 400;
  line-height: 1.24;
  color: #FDF9F3;
}

.bandFacts {
  margin-top: 34px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.bandFacts div {
  padding-top: 18px;
  border-top: 1px solid rgba(232, 207, 164, 0.18);
}

.bandFacts strong {
  display: block;
  font-family: var(--serif);
  font-size: 20px;
  color: #E8CFA4;
  font-weight: 500;
}

.bandFacts span {
  display: block;
  margin-top: 8px;
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(253, 249, 243, 0.7);
}

.prestations {
  padding: 86px 0 92px;
  background: #F6F1E9;
}

.prestationsGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

.prestationCard {
  background: #FCF8F2;
  border: 1px solid rgba(198, 161, 110, 0.14);
  border-radius: 12px;
  padding: 14px 14px 18px;
}

.prestationCard img {
  width: 100%;
  aspect-ratio: 1.08 / 0.86;
  object-fit: cover;
  border-radius: 8px;
}

.prestationCard h3 {
  margin-top: 14px;
  font-family: var(--serif);
  font-size: 22px;
  line-height: 1.2;
  font-weight: 500;
  color: #1F1D1A;
}

.prestationCard p {
  margin-top: 10px;
  font-size: 13px;
  line-height: 1.8;
  color: #5F5A53;
}

.pricing {
  padding: 0 0 96px;
  background: #F6F1E9;
}

.pricingGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}

.priceCard {
  background: #FCF8F2;
  border: 1px solid rgba(198, 161, 110, 0.14);
  border-radius: 14px;
  padding: 28px 24px;
}

.featured {
  background: #F3EADF;
  border-color: rgba(198, 161, 110, 0.3);
  transform: translateY(-4px);
}

.priceCard h3 {
  font-family: var(--serif);
  font-size: 28px;
  font-weight: 500;
  color: #1F1D1A;
}

.priceText {
  margin-top: 10px;
  font-size: 13px;
  line-height: 1.8;
  color: #5F5A53;
}

.priceCard ul {
  margin-top: 18px;
  display: grid;
  gap: 8px;
}

.priceCard li {
  font-size: 13px;
  line-height: 1.7;
  color: #5F5A53;
}

.priceWrap {
  margin-top: 22px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.price {
  font-family: var(--serif);
  font-size: 42px;
  line-height: 1;
  color: #1F1D1A;
}

.priceWrap small {
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #C6A16E;
}

.finalCta {
  background: #12160F;
  padding: 96px 0 104px;
  text-align: center;
}

.finalTitle {
  font-family: var(--serif);
  font-size: clamp(36px, 4vw, 56px);
  line-height: 1.1;
  font-weight: 400;
  color: #FDF9F3;
}

.finalText {
  margin: 20px auto 0;
  max-width: 720px;
  font-size: 15px;
  line-height: 1.9;
  color: rgba(253, 249, 243, 0.72);
}

.ctaButton {
  margin-top: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  padding: 0 26px;
  border-radius: 999px;
  background: #C6A16E;
  color: white;
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

@media (max-width: 980px) {
  .convictionShell {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .convictionVisual {
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
  }

  .convictionSideGrid {
    gap: 18px;
  }

  .conviction .container,
  .bandFacts,
  .prestationsGrid,
  .pricingGrid {
    grid-template-columns: 1fr 1fr;
  }

  .duoGrid {
    grid-template-columns: 1fr;
  }

  .convictionImages {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 720px) {
  .conviction {
    padding: 72px 0 78px;
  }

  .convictionTitle {
    font-size: 48px;
    line-height: 1.12;
  }

  .convictionBody,
  .convictionBodySecondary {
    font-size: 15px;
    line-height: 1.85;
  }

  .convictionVisual {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .convictionSideGrid {
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .convictionMainCard {
    transform: none;
  }

  .container,
  .bandInner {
    width: min(100% - 32px, 1220px);
  }

  .conviction .container,
  .bandFacts,
  .prestationsGrid,
  .pricingGrid {
    grid-template-columns: 1fr;
  }

  .featured {
    transform: none;
  }
}
