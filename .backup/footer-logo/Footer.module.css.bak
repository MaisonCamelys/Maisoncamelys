.footer {
  background: var(--olive);
  padding: 80px 52px 0;
  position: relative;
  overflow: hidden;
}

.botanical {
  position: absolute;
  right: -20px;
  bottom: 0;
  top: 0;
  width: 180px;
  pointer-events: none;
  opacity: 0.3;
  display: flex;
  align-items: center;
}

.inner {
  max-width: 1220px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 60px;
  align-items: start;
  padding-bottom: 64px;
  border-bottom: 1px solid rgba(196,154,60,0.14);
  position: relative;
  z-index: 2;
}

.brand {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.name {
  font-family: var(--serif);
  font-size: 19px;
  font-weight: 500;
  letter-spacing: 0.1em;
  color: var(--gold-pale);
}

.tagline {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(253,250,245,0.32);
  max-width: 240px;
  line-height: 1.6;
}

.links {
  display: flex;
  flex-direction: column;
  gap: 16px;
  align-items: center;
}

.link {
  font-size: 10.5px;
  font-weight: 400;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(253,250,245,0.5);
  transition: color 0.3s;
}
.link:hover { color: var(--gold-pale); }

.contact {
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: flex-end;
}

.email {
  font-size: 13px;
  font-weight: 300;
  color: rgba(253,250,245,0.6);
  transition: color 0.3s;
  letter-spacing: 0.04em;
}
.email:hover { color: var(--gold-pale); }

.zone {
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(253,250,245,0.28);
}

.bottom {
  max-width: 1220px;
  margin: 0 auto;
  padding: 22px 0;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 2;
}
.bottom p {
  font-size: 10px;
  font-weight: 300;
  color: rgba(253,250,245,0.22);
  letter-spacing: 0.12em;
}

@media (max-width: 768px) {
  .inner {
    grid-template-columns: 1fr;
    gap: 36px;
  }
  .links { align-items: flex-start; }
  .contact { align-items: flex-start; }
  .footer { padding-left: 24px; padding-right: 24px; }
}
