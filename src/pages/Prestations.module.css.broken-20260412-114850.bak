/* ═══════════════════════════════════
   HERO
═══════════════════════════════════ */
.hero {
  position: relative;
  min-height: 72vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.heroImg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 40%;
  animation: scaleIn 1.5s ease forwards;
}
.heroOverlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(42,48,32,0.88) 0%, rgba(42,48,32,0.35) 60%, transparent 100%);
}
.heroContent {
  position: relative;
  z-index: 2;
  padding: 0 72px 100px;
  max-width: 860px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.heroTitle {
  font-family: var(--serif);
  font-size: clamp(38px, 5.5vw, 74px);
  font-weight: 300;
  line-height: 1.15;
  color: #FDFAF5;
}
.heroTitle em { font-style: italic; color: var(--gold-pale); }
.heroSub {
  font-size: 15px;
  font-weight: 300;
  line-height: 1.85;
  color: rgba(253,250,245,0.58);
  max-width: 520px;
}
.heroWave {
  position: absolute;
  bottom: -2px; left: 0; right: 0;
  line-height: 0; pointer-events: none; z-index: 3;
}
.heroWave svg { width: 100%; height: 64px; display: block; }

/* ═══════════════════════════════════
   SERVICES
═══════════════════════════════════ */
.services {
  background: var(--cream);
  padding: 110px 52px;
}
.servicesInner {
  max-width: 1120px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 80px;
}
.serviceRow {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 72px;
  align-items: center;
}
.serviceRowReverse { direction: rtl; }
.serviceRowReverse > * { direction: ltr; }

.serviceImg {
  overflow: hidden;
  border-radius: 6px;
  height: 420px;
}
.serviceImg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 1.2s ease, filter 0.6s ease;
  filter: brightness(0.96);
}
.serviceRow:hover .serviceImg img {
  transform: scale(1.06);
  filter: brightness(1);
}

.serviceContent {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.serviceNum {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.28em;
  color: var(--gold);
}
.serviceTitle {
  font-family: var(--serif);
  font-size: clamp(26px, 3vw, 40px);
  font-weight: 400;
  line-height: 1.2;
  color: var(--text-dark);
}
.serviceDesc {
  font-size: 14.5px;
  font-weight: 300;
  line-height: 1.88;
  color: var(--text-mid);
}
.serviceItems {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 4px;
}
.serviceItems li {
  display: flex;
  align-items: baseline;
  gap: 12px;
  font-size: 13px;
  font-weight: 300;
  color: var(--text-mid);
}
.itemDash { color: var(--gold); font-size: 14px; flex-shrink: 0; }

/* ═══════════════════════════════════
   PACKS
═══════════════════════════════════ */
.packs {
  background: var(--cream-2);
  padding: 110px 52px;
}
.packsInner {
  max-width: 1120px;
  margin: 0 auto;
}
.packsTitle {
  font-family: var(--serif);
  font-size: clamp(28px, 3vw, 42px);
  font-weight: 400;
  line-height: 1.25;
  color: var(--text-dark);
  margin-top: 14px;
}
.packsGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border: 1px solid rgba(196,154,60,0.14);
  border-radius: 8px;
  overflow: hidden;
}
.packCard {
  background: var(--ivory);
  padding: 52px 36px 48px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  position: relative;
  border-right: 1px solid rgba(196,154,60,0.12);
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}
.packCard:last-child { border-right: none; }
.packCard:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 60px rgba(0,0,0,0.06);
}

.packHighlight {
  background: var(--olive);
  border-color: transparent !important;
}
.packBadge {
  display: inline-flex;
  align-items: center;
  background: var(--gold);
  color: #fff;
  font-size: 8.5px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 20px;
  width: fit-content;
}
.packName {
  font-family: var(--serif);
  font-size: 26px;
  font-weight: 500;
  color: var(--text-dark);
}
.packHighlight .packName { color: var(--gold-pale); }
.packSub {
  font-size: 12.5px;
  font-style: italic;
  font-weight: 300;
  color: var(--text-light);
  line-height: 1.6;
}
.packHighlight .packSub { color: rgba(253,250,245,0.42); }
.packList {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 11px;
}
.packList li {
  display: flex;
  align-items: baseline;
  gap: 12px;
  font-size: 13px;
  font-weight: 300;
  color: var(--text-mid);
}
.packHighlight .packList li { color: rgba(253,250,245,0.58); }
.packList span { color: var(--gold); flex-shrink: 0; }
.packPrice {
  font-family: var(--serif);
  font-size: 36px;
  font-weight: 400;
  color: var(--gold);
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.packPrice small {
  font-family: var(--sans);
  font-size: 11px;
  color: var(--text-light);
  font-weight: 300;
}
.packHighlight .packPrice small { color: rgba(253,250,245,0.38); }
.packCta {
  display: inline-flex;
  justify-content: center;
  padding: 12px 28px;
  border: 1px solid rgba(196,154,60,0.36);
  color: var(--text-dark);
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border-radius: 40px;
  width: fit-content;
  transition: background 0.3s, color 0.3s, border-color 0.3s;
}
.packCta:hover { background: var(--gold); border-color: var(--gold); color: #fff; }
.packCtaGold { background: var(--gold); border-color: var(--gold); color: #fff !important; }
.packCtaGold:hover { background: var(--gold-light); border-color: var(--gold-light); }
.packNote {
  font-family: var(--serif);
  font-size: 16px;
  font-style: italic;
  color: var(--text-mid);
  margin-bottom: 14px;
}
.packNoteLink {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: gap 0.25s, color 0.3s;
}
.packNoteLink:hover { gap: 14px; color: var(--olive); }

/* ═══════════════════════════════════
   CTA
═══════════════════════════════════ */
.cta {
  background: var(--olive-mid);
  padding: 120px 52px;
  text-align: center;
}
.ctaTitle {
  font-family: var(--serif);
  font-size: clamp(34px, 5vw, 64px);
  font-weight: 300;
  color: var(--ivory);
  line-height: 1.2;
  margin: 14px 0 18px;
}
.ctaSub {
  font-size: 15px;
  font-weight: 300;
  color: rgba(253,250,245,0.48);
  margin-bottom: 44px;
  line-height: 1.85;
}
.ctaBtn {
  display: inline-flex;
  align-items: center;
  padding: 15px 44px;
  background: var(--gold);
  color: #fff;
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  border-radius: 40px;
  transition: background 0.3s, transform 0.25s, box-shadow 0.3s;
  box-shadow: 0 4px 24px rgba(196,154,60,0.3);
}
.ctaBtn:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(196,154,60,0.42); }

/* ═══════════════════════════════════
   RESPONSIVE
═══════════════════════════════════ */
@media (max-width: 1024px) {
  .packsGrid { grid-template-columns: 1fr; border-radius: 8px; }
  .packCard { border-right: none !important; border-bottom: 1px solid rgba(196,154,60,0.12); }
  .packCard:last-child { border-bottom: none; }
}
@media (max-width: 768px) {
  .heroContent { padding: 0 28px 80px; }
  .serviceRow, .serviceRowReverse { grid-template-columns: 1fr; direction: ltr; }
  .serviceImg { height: 280px; }
  .services, .packs, .cta { padding-left: 24px; padding-right: 24px; }
}

@keyframes scaleIn {
  from { transform: scale(1.07); }
  to   { transform: scale(1); }
}
