          className={featured ? 'text-[clamp(2.1rem,2.5vw,3rem)] text-[#D8B36A]' : 'text-[clamp(2.1rem,2.5vw,3rem)] text-[#1F1D1A]'}
          style={{ fontFamily: 'var(--serif)', fontWeight: 400 }}
        >
          {pack.price}
        </p>
      </div>

      <div className="mt-8">
        <Link
          to="/contact"
          className={[
            'inline-flex items-center rounded-full px-6 py-3 text-[11px] uppercase tracking-[0.18em] transition',
