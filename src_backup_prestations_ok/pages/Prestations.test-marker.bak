function SectionKicker({ children }) {
  return (
    <p className="text-[11px] uppercase tracking-[0.24em] text-[#C6A16E]">
      {children}
    </p>
  )
}

function SectionTitle({ children, className = '' }) {
  return (
    <h2
      className={['text-[clamp(2rem,3vw,3.4rem)] leading-[1.08] text-[#1F1D1A]', className].join(' ')}
      style={{ fontFamily: 'var(--serif)', fontWeight: 400 }}
    >
      {children}
    </h2>
  )
}

function PackCard({ pack }) {
  const featured = pack.featured

  return (
    <article
      className={[
        'relative h-full rounded-[28px] border px-7 py-8 md:px-8 md:py-9',
        featured
          ? 'border-[#26311B] bg-[#24301A] text-[#F7F3EE] shadow-[0_18px_45px_rgba(31,29,26,0.10)]'
          : 'border-[#DDD4C9] bg-[#FCFAF7] text-[#1F1D1A] shadow-[0_10px_28px_rgba(31,29,26,0.04)]',
      ].join(' ')}
    >
