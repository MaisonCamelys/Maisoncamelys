      </p>

      <div className={featured ? 'mt-8 border-t border-white/10 pt-7' : 'mt-8 border-t border-[#E8E0D6] pt-7'}>
        <p className="text-[11px] uppercase tracking-[0.2em] text-[#C6A16E]">
          Résultat
        </p>
        <p className={featured ? 'mt-3 text-[16px] leading-8 text-[#F4EEE3]' : 'mt-3 text-[16px] leading-8 text-[#2D2A26]'}>
